Mobile Grocery App HTML
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Mobile Grocery Cart</title>
<style>
*{box-sizing:border-box}body{margin:0;font-family:Arial,Helvetica,sans-serif;background:#eef4f7;color:#14212b;padding-bottom:190px}header{position:sticky;top:0;z-index:2;background:#fff;border-bottom:1px solid #d9e2ec;padding:14px 16px}h1{font-size:1.45rem;margin:0}.subtitle{margin:5px 0 0;color:#667085;font-size:.88rem}.budget{display:grid;grid-template-columns:1fr 112px;gap:10px;background:#fff;padding:12px 16px;border-bottom:1px solid #d9e2ec}label{display:block;font-size:.78rem;font-weight:800;margin-bottom:5px}input{width:100%;min-height:46px;border:1px solid #bac8d6;border-radius:8px;padding:10px;font:inherit}.items{display:grid;gap:12px;padding:14px 12px 22px}.card{background:#fff;border:1px solid #d9e2ec;border-radius:8px;padding:13px;box-shadow:0 12px 28px rgba(20,33,43,.12);display:grid;grid-template-columns:62px 1fr;gap:12px}.icon{width:62px;height:62px;border-radius:8px;display:grid;place-items:center;background:#edf7f4;font-size:2.1rem}.card h2{font-size:1.08rem;margin:0 0 4px}.unit{margin:0;color:#667085;font-size:.84rem}.price,.controls,.item-total{grid-column:1/-1}.controls{display:grid;grid-template-columns:56px 1fr 56px;gap:10px}.tap{min-height:54px;border:0;border-radius:8px;font-size:1.6rem;font-weight:900;background:#e8eef5}.tap.add{background:#0f766e;color:#fff}.count{display:grid;place-items:center;min-height:54px;border:1px solid #d9e2ec;border-radius:8px;font-weight:900}.item-total{display:flex;justify-content:space-between;color:#667085}.item-total strong{color:#115e59}.checkout{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top:1px solid #d9e2ec;box-shadow:0 -12px 30px rgba(20,33,43,.16);padding:12px 14px}.receipt{max-height:64px;overflow:auto}.row{display:flex;justify-content:space-between;gap:12px;padding:4px 0}.grand{font-size:1.28rem;font-weight:900}.balance{margin-top:8px;padding:10px;border-radius:8px;text-align:center;background:#e9f8f4;color:#047857;font-weight:900}.balance.over{background:#fff1f2;color:#b91c1c}.actions{display:flex;gap:10px;margin-top:10px}.actions button{border:0;border-radius:8px;min-height:44px;padding:9px 12px;font-weight:900}.top{flex:1;background:#12343b;color:#fff}.clear{background:#e8eef5;color:#334155}@media(min-width:700px){body{padding-bottom:0}.items{grid-template-columns:repeat(2,1fr);max-width:900px;margin:auto}.budget{max-width:900px;margin:auto}.checkout{position:sticky;max-width:900px;margin:auto;border:1px solid #d9e2ec;border-radius:8px 8px 0 0}}
</style>
</head>
<body>
<header id="top"><h1>Mobile Grocery Cart</h1><p class="subtitle">Tap item cards to add groceries and track your budget.</p></header>
<section class="budget"><div><label for="wallet">Wallet</label><input id="wallet" type="number" min="0" step="0.01" value="100"></div><div><label for="taxRate">Tax %</label><input id="taxRate" type="number" min="0" step="0.01" value="13"></div></section>
<main class="items" id="items"></main>
<section class="checkout"><div class="receipt" id="receipt"></div><div class="row"><span>Subtotal</span><strong id="subtotal">$0.00</strong></div><div class="row"><span>Tax</span><strong id="tax">$0.00</strong></div><div class="row grand"><span>Total</span><strong id="total">$0.00</strong></div><div class="balance" id="balance">$100.00 left</div><div class="actions"><button class="top" id="topButton">Back to top</button><button class="clear" id="clearButton">Clear</button></div></section>
<script>
const products=[['eggs','🥚','Eggs','1 dozen','Per dozen',4.49],['milk','🥛','Milk','4 litres','Per 4L',6.19],['bread','🍞','Bread','1 loaf','Per loaf',3.29],['butter','🧈','Butter','1 stick','Per stick',1.75],['bananas','🍌','Bananas','8 bananas','Per 8',2.40],['cheese','🧀','Cheese','500 grams','Per 500g',7.99],['apples','🍎','Apples','1 pound','Per pound',2.49],['potatoes','🥔','Potatoes','1 pound','Per pound',1.19],['tomatoes','🍅','Tomatoes','1 pound','Per pound',2.99]];
const counts=Object.fromEntries(products.map(p=>[p[0],0]));const cash=new Intl.NumberFormat('en-CA',{style:'currency',currency:'CAD'});const root=document.querySelector('#items');
const money=n=>cash.format(n);const value=id=>Number(document.querySelector('#'+id).value)||0;
function build(){root.innerHTML=products.map(p=>'<article class="card"><div class="icon">'+p[1]+'</div><div><h2>'+p[2]+'</h2><p class="unit">Adds '+p[3]+'</p></div><div class="price"><label for="'+p[0]+'Price">'+p[4]+' ($)</label><input id="'+p[0]+'Price" type="number" min="0" step="0.01" value="'+p[5].toFixed(2)+'"></div><div class="controls"><button class="tap" data-id="'+p[0]+'" data-action="minus">−</button><div class="count" id="'+p[0]+'Count">0</div><button class="tap add" data-id="'+p[0]+'" data-action="plus">+</button></div><div class="item-total"><span>Item total</span><strong id="'+p[0]+'Total">$0.00</strong></div></article>').join('')}
					function render(){let sub=0,lines=[];products.forEach(p=>{let id=p[0],cost=counts[id]*value(id+'Price');sub+=cost;document.querySelector('#'+id+'Count').textContent=counts[id];document.querySelector('#'+id+'Total').textContent=money(cost);if(counts[id])lines.push('<div class="row"><span>'+p[2]+' x '+counts[id]+'</span><strong>'+money(cost)+'</strong></div>')});let tax=sub*(value('taxRate')/100),total=sub+tax,left=value('wallet')-total;document.querySelector('#receipt').innerHTML=lines.join('')||'<div class="row">Your cart is empty.</div>';document.querySelector('#subtotal').textContent=money(sub);document.querySelector('#tax').textContent=money(tax);document.querySelector('#total').textContent=money(total);let b=document.querySelector('#balance');b.textContent=left>=0?money(left)+' left':money(Math.abs(left))+' over budget';b.classList.toggle('over',left<0)}
build();render();document.addEventListener('click',e=>{let b=e.target.closest('button[data-action]');if(!b)return;let id=b.dataset.id;if(b.dataset.action==='plus')counts[id]++;else counts[id]=Math.max(0,counts[id]-1);render()});document.querySelector('#clearButton').onclick=()=>{Object.keys(counts).forEach(id=>counts[id]=0);render()};document.querySelector('#topButton').onclick=()=>document.querySelector('#top').scrollIntoView({behavior:'smooth'});document.querySelectorAll('input').forEach(i=>i.addEventListener('input',render));
</script>
</body>
</html>